        <dependency>
            <groupId>cn.iocoder.boot</groupId>
            <artifactId>yudao-spring-boot-starter-security</artifactId>
        </dependency>

        <!-- 参数校验：@Valid、@NotNull、@NotBlank 等 -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
